# Chat UI for your local models: pick a model, talk to it, no cloud account.
OPEN_WEBUI_VERSION=main

# Which local LLM service to talk to. Must be a running Laradock service.
# ollama (default) or localai.
OPEN_WEBUI_LLM_ENGINE=ollama
OPEN_WEBUI_LLM_PORT=11434

OPEN_WEBUI_PORT=8322

# false = skip the login screen (local dev convenience). Only takes effect on a
# fresh install: once an account exists, Open WebUI keeps asking for it.
OPEN_WEBUI_AUTH=true
