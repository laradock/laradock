#!/usr/bin/env bash
#
# Laradock CLI — optional convenience layer over plain Docker Compose.
#
#   ./laradock start     start your services (first run: walks you through setup)
#   ./laradock stop      stop them (data kept) · restart · remove · rebuild · logs
#   ./laradock enter <s> open a terminal inside a container (e.g. mysql)
#   ./laradock setup     re-run the interactive wizard, writes .env only
#   ./laradock workspace enter the Laradock Workspace (dev shell)
#   ./laradock info      show running services, URLs, credentials
#   ./laradock doctor    diagnose common problems
#   ./laradock <other>   passed straight to `docker compose <other>`
#
# Design contract: no state, no generated files, every command prints the real
# docker compose command it runs. Plain `docker compose` always works too.
# Requires: bash 3.2+, Docker with Compose v2.20+.

set -u

VERSION="1.0.0"
MIN_COMPOSE_MINOR=20   # v2.20+ needed for `include`
ESC=$(printf '\033')
EOL=$(printf '\033[K')   # erase to end of line
BS=$(printf '\010'); DEL=$(printf '\177')   # backspace variants

# ---------------------------------------------------------------- ui helpers

setup_color() {
  C_RESET='' C_BOLD='' C_DIM='' C_RED='' C_GREEN='' C_YELLOW='' C_CYAN='' C_INV=''
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-dumb}" != "dumb" ]; then
    C_RESET=$(printf '\033[0m');  C_BOLD=$(printf '\033[1m');  C_DIM=$(printf '\033[2m')
    C_RED=$(printf '\033[31m');   C_GREEN=$(printf '\033[32m')
    C_YELLOW=$(printf '\033[33m'); C_CYAN=$(printf '\033[36m'); C_INV=$(printf '\033[7m')
  fi
  OK="${C_GREEN}✓${C_RESET}"; BAD="${C_RED}✗${C_RESET}"; WARN_SYM="${C_YELLOW}⚠${C_RESET}"; ARROW="→"
  LINE_CH="─"; TICK="▸"
  case "${LANG:-}${LC_ALL:-}" in
    *UTF-8*|*utf8*) : ;;
    *) OK="${C_GREEN}[ok]${C_RESET}"; BAD="${C_RED}[x]${C_RESET}"; WARN_SYM="${C_YELLOW}[!]${C_RESET}"; ARROW="->"
       LINE_CH="-"; TICK=">" ;;
  esac
}

say()  { printf '%s\n' "$*"; }
bold() { printf '%s%s%s\n' "$C_BOLD" "$*" "$C_RESET"; }
ok()   { printf '  %s %s\n' "$OK" "$*"; }
bad()  { printf '  %s %s\n' "$BAD" "$*"; }
note() { printf '  %s %s\n' "$WARN_SYM" "$*"; }
warn() { printf '  %s%s%s\n' "$C_YELLOW" "$*" "$C_RESET"; }
die()  {  # die "problem" [hint lines...] — red headline + dim what-to-do lines, then exit
  printf '\n  %s %s%s%s\n' "$BAD" "$C_BOLD" "$1" "$C_RESET" >&2
  shift
  local _h
  for _h in "$@"; do printf '     %s\n' "$_h" >&2; done
  printf '\n' >&2
  exit 1
}

# print the real command, then run it
run() { printf '  %s%s docker compose %s%s\n' "$C_DIM" "$ARROW" "$*" "$C_RESET"; docker compose "$@"; }

is_tty() { [ -t 0 ] && [ -t 1 ]; }

# ------------------------------------------------------------ input helpers
# ask VAR "Question" "default" — free text with default
ask() {
  local _var=$1 _q=$2 _def=$3 _ans=''
  if [ "$ASSUME_YES" = 1 ] || ! is_tty; then
    eval "$_var=\"\$_def\""
    printf '  %-14s %s[%s]%s\n' "$_q" "$C_CYAN" "$_def" "$C_RESET"
    return
  fi
  printf '  %-14s %s[%s]%s ' "$_q" "$C_CYAN" "$_def" "$C_RESET"
  IFS= read -r _ans || _ans=''
  [ -n "$_ans" ] || _ans=$_def
  eval "$_var=\"\$_ans\""
}

confirm() {  # confirm "Question" default(Y|n) -> return 0 yes
  local _q=$1 _def=${2:-Y} _ans
  if [ "$ASSUME_YES" = 1 ] || ! is_tty; then
    [ "$_def" = Y ] && { printf '  %s %s[Y]%s\n' "$_q" "$C_CYAN" "$C_RESET"; return 0; }
    printf '  %s %s[n]%s\n' "$_q" "$C_CYAN" "$C_RESET"; return 1
  fi
  local _hint='[Y/n]'; [ "$_def" = n ] && _hint='[y/N]'
  printf '  %s %s%s%s ' "$_q" "$C_CYAN" "$_hint" "$C_RESET"
  IFS= read -r _ans || _ans=''
  [ -n "$_ans" ] || _ans=$_def
  case "$_ans" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

# --------------------------------------------------------------- env helpers

env_get() {  # env_get KEY [file] -> prints value or empty (strips our marker)
  local _f=${2:-.env}
  [ -f "$_f" ] || return 0
  sed -n "s/^${1}=//p" "$_f" | tail -1 | sed 's/ # set by laradock.*//'
}

env_set() {  # env_set KEY VALUE — update in place or append (preserves everything else)
  local _k=$1 _v=$2
  touch .env
  if grep -q "^${_k}=" .env; then
    # portable in-place edit (BSD/GNU sed differ; use tmp file)
    sed "s|^${_k}=.*|${_k}=${_v}|" .env > .env.tmp.$$ && mv .env.tmp.$$ .env
  else
    ## if .env does not have an empty line at the end, add one first, otherwise the last line will be overwritten
    if [ -s .env ] && [ "$(tail -c 1 .env)" != "" ]; then
      printf '\n' >> .env
    fi
    printf '%s=%s\n' "$_k" "$_v" >> .env
  fi
}

# Compose is strict about project names: lowercase alphanumerics, - and _ only, and it
# must start with a letter or digit. We default the name to the parent folder, and folder
# names like "My-App" or "-Open-Source" are perfectly normal, so fold it into something
# compose accepts instead of letting `up` die with a wall of docker text on first run.
sanitize_project_name() {
  local _n
  _n=$(printf '%s' "$1" | tr 'A-Z' 'a-z' | tr -c 'a-z0-9_-' '-' | sed 's/^[^a-z0-9]*//; s/[^a-z0-9]*$//')
  printf '%s' "${_n:-my-app}"
}

default_of() {  # default_of KEY — value from .env, else .env.example, else $2
  local _v
  _v=$(env_get "$1" .env)
  [ -n "$_v" ] || _v=$(env_get "$1" .env.example)
  [ -n "$_v" ] || _v=${2:-}
  printf '%s' "$_v"
}

# ------------------------------------------------------------ sanity checks

require_laradock_dir() {
  [ -f docker-compose.yml ] && grep -q '^include:' docker-compose.yml \
    || die "This doesn't look like the laradock folder." \
           "${C_DIM}Go into the folder you cloned (it contains docker-compose.yml):${C_RESET} ${C_CYAN}cd laradock${C_RESET}${C_DIM}, then retry.${C_RESET}"
}

compose_version() {
  docker compose version --short 2>/dev/null | sed 's/^v//'
}

compose_version_ok() {  # true if >= 2.20 (any major > 2 passes)
  local _v _maj _min
  _v=$(compose_version); [ -n "$_v" ] || return 1
  _maj=${_v%%.*}; _min=$(printf '%s' "$_v" | awk -F. '{print $2}')
  [ "$_maj" -gt 2 ] 2>/dev/null && return 0
  [ "$_maj" -eq 2 ] 2>/dev/null && [ "${_min:-0}" -ge "$MIN_COMPOSE_MINOR" ] 2>/dev/null
}

check_docker() {
  command -v docker >/dev/null 2>&1 \
    || die "Docker is not installed." \
           "${C_DIM}Install Docker Desktop from${C_RESET} https://docs.docker.com/get-docker/ ${C_DIM}then retry.${C_RESET}"
  docker info >/dev/null 2>&1 \
    || die "Docker is installed but not running." \
           "${C_DIM}Open Docker Desktop (or start the docker service), wait until it says it's ready, then retry.${C_RESET}"
  docker compose version >/dev/null 2>&1 \
    || die "Docker Compose v2 not found." \
           "${C_DIM}The old docker-compose v1 cannot read this project. Update Docker to the latest version, then retry.${C_RESET}"
  compose_version_ok \
    || die "Docker Compose v2.${MIN_COMPOSE_MINOR}+ required (you have v$(compose_version))." \
           "${C_DIM}Update Docker to the latest version, then retry.${C_RESET}"
}

# --------------------------------------------------------- framework detect

detect_framework() {  # prints: laravel|wordpress|symfony|drupal|php|none
  local _app=$1
  [ -d "$_app" ] || { printf 'none'; return; }
  if   [ -f "$_app/artisan" ];                                       then printf 'laravel'
  elif [ -f "$_app/wp-settings.php" ] || [ -f "$_app/wp-config.php" ]; then printf 'wordpress'
  elif [ -f "$_app/symfony.lock" ] || [ -f "$_app/config/bundles.php" ]; then printf 'symfony'
  elif [ -f "$_app/core/lib/Drupal.php" ];                           then printf 'drupal'
  elif [ -f "$_app/composer.json" ] || [ -f "$_app/index.php" ];     then printf 'php'
  else printf 'none'; fi
}

# -------------------------------------------------------------- cmd: setup

# The stack your answers add up to: web server + PHP runtime + database + cache + extras,
# and always the workspace. The review screen shows this before anything is written, so
# "what am I actually getting" is answered on screen instead of after the fact.
build_services() {
  local _s=""
  [ "$W_WS" != none ] && _s="$W_WS"
  [ -n "$W_RUNTIME" ] && _s="$_s $W_RUNTIME"
  [ "$W_DB" != none ] && _s="$_s $W_DB"
  [ "$W_CACHE" != none ] && _s="$_s $W_CACHE"
  [ -n "$W_EXTRAS" ] && _s="$_s $W_EXTRAS"
  _s="$_s workspace"
  printf '%s' "$_s" | sed 's/^ *//;s/  */ /g'
}

cmd_setup() {
  require_laradock_dir
  bold ""
  bold "  Laradock setup"
  say  "  ─────────────────────────────────────────────"
  check_docker
  ok "Docker running · Compose v$(compose_version) (needs 2.${MIN_COMPOSE_MINOR}+)"

  [ -f .env ] || { [ -f .env.example ] && cp .env.example .env && ok "created .env from .env.example"; }

  # -- detect the app to pre-answer everything
  app_path=$(default_of APP_CODE_PATH_HOST "../")
  fw=$(detect_framework "$app_path")
  parent_name=$(basename "$(cd "$app_path" 2>/dev/null && pwd || echo my-app)")
  # seed the picker only on a SPECIFIC detection; generic "php" starts at the top
  case "$fw" in none|php) fw_item_def="" ;; *) fw_item_def=$fw ;; esac
  case "$fw" in
    none) warn "no PHP project detected at $app_path (pick a type below, or change App path)";;
    php)  ok "Detected: a PHP project  (at $app_path)";;
    *)    ok "Detected: $fw  (at $app_path)";;
  esac

  name_def=$(env_get COMPOSE_PROJECT_NAME)
  case "$name_def" in ''|laradock) name_def=$(sanitize_project_name "$parent_name") ;; esac

  # answers (globals so ask_* helpers can re-ask any single one)
  W_CAT='' W_TYPE='' W_PHP='' W_RUNTIME='' W_WS='' W_DB='' W_CACHE='' W_EXTRAS='' W_TOOLS='' W_NAME='' W_PATH=''
  seed_from_env   # re-run: pre-fill with the stack you already have

  say ""
  say "  ${C_DIM}Ten questions. Every one has a sensible answer pre-selected, so if you're not${C_RESET}"
  say "  ${C_DIM}sure, press enter and move on. You get to review everything before it's saved.${C_RESET}"
  STEP_TOTAL=10
  ask_type;  ask_php;  ask_runtime;  ask_ws;  ask_db;  ask_cache;  ask_extras;  ask_tools;  ask_name;  ask_path
  STEP_N=''
  tools_before=$(ws_tools_on)   # to tell you afterwards whether workspace needs a rebuild

  # -- review screen: change anything before applying
  if [ "$ASSUME_YES" != 1 ] && is_tty; then
    while :; do
      say ""
      # Grouped, because ten flat rows is a list to audit; five little groups is a thing
      # you recognise. Numbers stay in order so they still read 1..10 top to bottom.
      local _line; _line=$(rule)
      printf '  %s%s%s\n' "$C_DIM" "$_line" "$C_RESET"
      printf '  %sReview your choices%s  %snothing is written yet%s\n' "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET"
      printf '  %s%s%s\n' "$C_DIM" "$_line" "$C_RESET"
      _rgrp() { printf '\n  %s%s %s%s\n' "$C_YELLOW$C_BOLD" "$TICK" "$1" "$C_RESET"; }
      _rrow() { printf '   %s%2s)%s %-16s %s%s%s\n' "$C_DIM" "$1" "$C_RESET" "$2" "$C_GREEN" "$3" "$C_RESET"; }
      # A list too long for one row gets wrapped under it, never truncated: this screen is
      # the last look before it's written, so "+7 more" is exactly what you can't hide.
      _rlist() {
        local _w _l; _w=$(tput cols 2>/dev/null || echo 80); [ "$_w" -gt 74 ] && _w=74
        # `|| [ -n "$_l" ]`: paste/fold leave the last line without a newline, and a plain
        # `read` returns false at EOF and would silently drop it — the exact truncation
        # this function exists to prevent.
        printf '%s' "$1" | tr ' ' '\n' | paste -sd, - | sed 's/,/, /g' | fold -s -w $((_w - 24)) |
          while IFS= read -r _l || [ -n "$_l" ]; do printf '%*s%s%s%s\n' 24 '' "$C_GREEN" "${_l% }" "$C_RESET"; done
      }
      _rgrp "Your app"
      _rrow 1 Project          "$W_TYPE"
      _rgrp "PHP"
      _rrow 2 "Version"        "$W_PHP"
      _rrow 3 "Runtime"        "$W_RUNTIME"
      _rgrp "Services to run"
      _rrow 4 "Web server"     "$W_WS"
      _rrow 5 "Database"       "$W_DB"
      _rrow 6 "Cache"          "$W_CACHE"
      if [ -n "$W_EXTRAS" ]; then _rrow 7 "Extras" "$(printf '%s' "$W_EXTRAS" | wc -w | tr -d ' ') selected"; _rlist "$W_EXTRAS"
      else _rrow 7 "Extras" "none"; fi
      _rgrp "Dev shell"
      if [ -n "$W_TOOLS" ]; then _rrow 8 "Workspace tools" "$(printf '%s' "$W_TOOLS" | wc -w | tr -d ' ') installed"; _rlist "$W_TOOLS"
      else _rrow 8 "Workspace tools" "none"; fi
      _rgrp "Naming & location"
      _rrow 9 "Project name"   "$W_NAME"
      _rrow 10 "App path"      "$W_PATH"
      say ""
      printf '  %s%s%s\n' "$C_DIM" "$_line" "$C_RESET"
      printf '  %sStarts %s containers:%s %s%s%s\n' "$C_DIM" "$(build_services | wc -w | tr -d ' ')" "$C_RESET" "$C_CYAN" "$(build_services)" "$C_RESET"
      printf '  %s%s%s\n' "$C_DIM" "$_line" "$C_RESET"
      printf '  %sEnter%s = apply · %s1-10%s = change that answer · %sq%s = quit ' \
        "$C_CYAN" "$C_RESET" "$C_CYAN" "$C_RESET" "$C_CYAN" "$C_RESET"
      IFS= read -r _r || _r=''
      case "$_r" in
        '') break ;;
        1) ask_type ;;  2) ask_php ;;  3) ask_runtime ;;  4) ask_ws ;;  5) ask_db ;;
        6) ask_cache ;; 7) ask_extras ;; 8) ask_tools ;; 9) ask_name ;; 10) ask_path ;;
        q|Q) say "  nothing written."; exit 0 ;;
      esac
    done
  fi

  local services; services=$(build_services)

  # -- write laradock .env (only the overrides)
  say ""
  bold "  Writing .env overrides:"
  env_set COMPOSE_PROJECT_NAME "$W_NAME"
  # shellcheck disable=SC2088  # literal ~ is intended: docker compose expands it in volume paths
  env_set DATA_PATH_HOST "~/.laradock/data-$W_NAME"
  env_set PHP_VERSION "$W_PHP"
  env_set APP_CODE_PATH_HOST "$W_PATH"
  env_set LARADOCK_SERVICES "\"$services\""
  for kv in "COMPOSE_PROJECT_NAME=$W_NAME" "DATA_PATH_HOST=~/.laradock/data-$W_NAME" \
            "PHP_VERSION=$W_PHP" "APP_CODE_PATH_HOST=$W_PATH" "LARADOCK_SERVICES=\"$services\""; do
    say "    $kv"
  done
  # Workspace tools: write only what you changed. A tool left on its shipped value gets
  # no line at all (and any stale override is dropped), so .env stays a diff of your
  # choices rather than a copy of all ~80 flags.
  local _t _k _d _want
  for _t in $(ws_all_tools); do
    _k=$(ws_tool_key "$_t"); _d=$(ws_tool_default "$_t")
    case " $W_TOOLS " in *" $_t "*) _want=true ;; *) _want=false ;; esac
    if [ "$_want" = "$_d" ]; then
      grep -q "^${_k}=" .env 2>/dev/null \
        && { sed "/^${_k}=/d" .env > .env.tmp.$$ && mv .env.tmp.$$ .env; say "    $_k back to default ($_d)"; }
    else
      env_set "$_k" "$_want"; say "    $_k=$_want"
    fi
  done
  say "    ${C_DIM}(everything else keeps its shipped default from <service>/defaults.env)${C_RESET}"

  # A tool change only lands when the workspace image is rebuilt; docker won't say so.
  if [ "$(ws_tools_on)" != "$tools_before" ] && docker compose ps -q workspace 2>/dev/null | grep -q .; then
    say ""
    note "workspace tools changed — run ${C_CYAN}./laradock rebuild workspace${C_RESET} to apply them."
  fi

  # -- offer to patch the app's .env
  patch_app_env "$W_PATH" "$W_DB" "$W_CACHE" "$W_EXTRAS"

  # When bootstrapped from `up`, skip both the start-offer and the epilogue below;
  # the caller starts the stack itself (avoids a double `up`).
  [ "${SKIP_START_OFFER:-0}" = 1 ] && return

  # -- offer to start the stack right now (interactive only; --yes writes config and stops)
  if [ "$ASSUME_YES" != 1 ] && is_tty; then
    say ""
    if confirm "Start your stack now ($services)?" Y; then
      # shellcheck disable=SC2086  # word-splitting the service list is intended
      cmd_up $services
      return
    fi
  fi

  # -- otherwise, tell them how to proceed
  say ""
  bold "  You're set. How to proceed:"
  say "    ./laradock start         start your stack: $services"
  say "    ./laradock workspace     Laradock Workspace: a dev shell with php, composer, node, git"
  say "    ./laradock info          URLs, ports, credentials of what's running"
  say "    ./laradock doctor        if anything misbehaves"
  local _egws=$W_WS; [ "$_egws" = none ] && _egws=nginx
  say "    ${C_DIM}Everything else passes through: ./laradock logs -f ${_egws} = docker compose logs -f ${_egws}${C_RESET}"
  say "    ${C_DIM}Docs: https://laradock.io/docs/cli${C_RESET}"
  say ""
}

# --- supported project types ---------------------------------------------
# SYNC: this list mirrors the "Supported PHP Projects" lists in README.md and
#       DOCUMENTATION/docs/Intro.md. Add a project = update ALL THREE places.
projects_framework() { echo "laravel symfony codeigniter yii laminas cakephp phalcon slim lumen fuelphp spiral hyperf api-platform mezzio flight fat-free thinkphp silex swoole workerman ubiquity silverstripe nette leaf"; }
projects_cms()       { echo "wordpress drupal joomla october statamic craftcms typo3 concrete grav backdrop htmly kirby processwire pico bolt contao b2evolution serendipity nucleus e107 pligg sulu pimcore wintercms neos textpattern expressionengine"; }
projects_ecommerce() { echo "magento woocommerce prestashop opencart sylius bagisto aimeos avored orocommerce zencart oscommerce abantecart cubecart shopware litecart openmage"; }
projects_app()       { echo "moodle mediawiki phpbb matomo mybb fluxbb punbb flarum bbpress smf dokuwiki bookstack roundcube phpmyadmin adminer suitecrm espocrm vtiger dolibarr aureus-erp weberp frontaccounting kanboard firefly-iii invoice-ninja x2crm nextcloud owncloud pydio mautic crater akaunting monica leantime cachet php-server-monitor yourls linkace koel azuracast lychee vanilla"; }

projects_in() {  # category -> space-separated items
  case "$1" in
    framework) projects_framework ;;
    cms)       projects_cms ;;
    ecommerce) projects_ecommerce ;;
    app)       projects_app ;;
  esac
}

category_of() {  # item -> its category (for pre-selecting from detection)
  local _c
  for _c in framework cms ecommerce app; do
    case " $(projects_in "$_c") " in *" $1 "*) echo "$_c"; return ;; esac
  done
  echo other
}

ws_default_for() {  # $1=category $2=project -> the web server it traditionally expects
  # frameworks and plain PHP default to nginx
  case "$1" in framework|other) echo nginx; return ;; esac
  # modern / flat-file / Laravel- or Symfony-based apps prefer nginx
  case "$2" in
    statamic|craftcms|october|wintercms|grav|neos|pimcore|kirby|sulu|bolt|pico|htmly|leaf|\
    flarum|bookstack|koel|crater|akaunting|monica|leantime|firefly-iii|invoice-ninja|azuracast|linkace|cachet|\
    sylius|bagisto|aimeos|avored|orocommerce|shopware) echo nginx ;;
    # traditional CMS / forum / e-commerce / apps assume Apache + .htaccess
    *) echo apache2 ;;
  esac
}

db_default_for() {  # project -> the database it expects (default mysql)
  # PostgreSQL-first stacks: Symfony's convention, and apps that require Postgres.
  case "$1" in symfony|orocommerce) echo postgres ;; *) echo mysql ;; esac
}

rec_extras_for() {  # project -> heavy services it REQUIRES to install & run (beyond web/db/cache)
  # Only services that work out of the box are pre-selected here; things that need a
  # config file first (e.g. php-worker) stay opt-in so "next-next" never starts a broken one.
  case "$1" in
    magento|openmage) echo "opensearch" ;;      # catalog search is mandatory on Magento 2.4
    orocommerce)      echo "rabbitmq elasticsearch" ;;  # Oro needs a message queue + search
    *)                echo "" ;;
  esac
}


