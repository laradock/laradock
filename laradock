# Every service the dev stack can actually start = every folder docker-compose.yml
# includes. Reading the include list (not the folders) keeps standalone compose files
# out: production/ is its own project (./laradock ship), multi-php/ is pulled in by
# docker-compose.multi-php.yml. Neither can be `start`ed, so neither is ever offered.
known_services() { sed -n 's#^  - path: \(.*\)/compose.yml$#\1#p' docker-compose.yml; }
service_other() {  # folders not categorized above and not workspace
  local _cat _s
  _cat=" $(service_groups | sed 's/^[^|]*|//' | tr '\n' ' ') "
  for _s in $(known_services); do
    # workspace is auto-added; php-fpm/roadrunner are the PHP-runtime question, not extras
    case "$_s" in workspace|php-fpm|roadrunner) continue ;; esac
    case "$_cat" in *" $_s "*) : ;; *) printf '%s ' "$_s" ;; esac
  done
}
# print a space-separated list in aligned columns to the terminal width
print_cols() {
  local _list=$1 _indent=${2:-4}
  local _w; _w=$(tput cols 2>/dev/null || echo 80); [ "$_w" -gt 180 ] && _w=180
  local _it _max=0
  for _it in $_list; do [ ${#_it} -gt "$_max" ] && _max=${#_it}; done
  [ "$_max" -eq 0 ] && return
  local _cw=$((_max + 2)) _ncol _i=0
  _ncol=$(( (_w - _indent) / _cw )); [ "$_ncol" -lt 1 ] && _ncol=1
  for _it in $_list; do
    [ $((_i % _ncol)) -eq 0 ] && printf '%*s' "$_indent" ''
    printf '%s%-*s%s' "$C_GREEN" "$_cw" "$_it" "$C_RESET"
    _i=$((_i + 1))
    [ $((_i % _ncol)) -eq 0 ] && printf '\n'
  done
  [ $((_i % _ncol)) -ne 0 ] && printf '\n'
}

# --- interactive grouped menu (single or multi select, type-to-filter) -------
# imenu MODE VAR PROMPT ROWSFN PRESET HELP
#   MODE=one|multi · ROWSFN echoes "H|Header" and "I|value" lines (grouped, ordered)
#   PRESET: one -> default value to highlight · multi -> space-separated preselected
#   HELP: one plain-English line shown under the prompt (what this is / why the default is fine)
# step_header "Title" "blurb"  — the same banner above every setup question, so each step
# is visibly its own thing instead of scrolling into the last one. STEP_N is set by the
# caller (not auto-incremented) so re-asking one answer from the review screen still shows
# that answer's own number. Blurb may contain \n for a second line.
rule() {  # rule [width] — a horizontal line, unicode where the terminal can take it
  local _w=${1:-0} _i _out=""
  [ "$_w" -gt 0 ] || { _w=$(tput cols 2>/dev/null || echo 80); [ "$_w" -gt 72 ] && _w=72; _w=$((_w - 2)); }
  for _i in $(seq 1 "$_w"); do _out="$_out$LINE_CH"; done
  printf '%s' "$_out"
}

step_header() {
  local _t=$1 _blurb=${2:-} _line
  _line=$(rule)
  say ""
  printf '  %s%s%s\n' "$C_DIM" "$_line" "$C_RESET"
  if [ -n "${STEP_N:-}" ]; then
    printf '  %sStep %s of %s%s  %s%s%s\n' "$C_DIM" "$STEP_N" "${STEP_TOTAL:-10}" "$C_RESET" "$C_BOLD" "$_t" "$C_RESET"
  else
    printf '  %s%s%s\n' "$C_BOLD" "$_t" "$C_RESET"
  fi
  printf '  %s%s%s\n' "$C_DIM" "$_line" "$C_RESET"
  [ -n "$_blurb" ] && printf '  %s%b%s\n' "$C_DIM" "$_blurb" "$C_RESET"
  say ""
}

imenu() {
  local _mode=$1 _var=$2 _prompt=$3 _rowsfn=$4 _preset=$5 _help=${6:-}
  local _ak=() _av=() _k _v
  while IFS='|' read -r _k _v; do _ak[${#_ak[@]}]=$_k; _av[${#_av[@]}]=$_v; done < <($_rowsfn)
  local _na=${#_ak[@]}
  if [ "$ASSUME_YES" = 1 ] || ! is_tty; then
    local _pv=$_preset _q
    if [ "$_mode" = one ] && [ -z "$_pv" ]; then
      for _q in $(seq 0 $((_na - 1))); do [ "${_ak[$_q]}" = I ] && { _pv=${_av[$_q]}; break; }; done
    fi
    eval "$_var=\"\$_pv\""
    printf '  %-14s %s[%s]%s\n' "$_prompt" "$C_CYAN" "${_pv:-none}" "$C_RESET"; return
  fi
  # A step reads top to bottom: what am I choosing -> what's on offer -> pick one.
  # Say each thing exactly once: the header names the step, the blurb explains it in
  # plain English, the keys line is the only place keys are mentioned.
  step_header "$_prompt" "$_help"
  say "  ${C_DIM}Everything Laradock offers here:${C_RESET}"
  local _ci _cbuf=""
  for _ci in $(seq 0 $((_na - 1))); do
    if [ "${_ak[$_ci]}" = H ]; then
      [ -n "$_cbuf" ] && { print_cols "$_cbuf"; _cbuf=""; }
      printf '  %s%s%s\n' "$C_BOLD$C_YELLOW" "${_av[$_ci]}" "$C_RESET"
    else
      _cbuf="$_cbuf ${_av[$_ci]}"
    fi
  done
  [ -n "$_cbuf" ] && print_cols "$_cbuf"
  local _selset=" " _p
  [ "$_mode" = multi ] && for _p in $_preset; do _selset="$_selset$_p "; done
  local _query="" _key _cur=0 _start=0 _win=14 _first=1 _seeded=0
  say ""
  if [ "$_mode" = multi ]; then
    printf '  %stype%s to filter · %s↑↓%s move · %sspace%s toggles on/off · %senter%s when done\n' \
      "$C_CYAN" "$C_RESET" "$C_CYAN" "$C_RESET" "$C_CYAN" "$C_RESET" "$C_CYAN" "$C_RESET"
  else
    printf '  %stype%s to filter · %s↑↓%s move · %senter%s to pick\n' \
      "$C_CYAN" "$C_RESET" "$C_CYAN" "$C_RESET" "$C_CYAN" "$C_RESET"
  fi
  printf '\033[?25l'
  trap 'printf "\033[?25h"' RETURN 2>/dev/null || true
  local _rk _rv _nr _lc _i _r _snap _p2 _mn _dv _j _pendhdr _hasitem _mk _out
  while :; do
    _lc=$(printf '%s' "$_query" | tr 'A-Z' 'a-z')
    _rk=(); _rv=(); _mn=0; _pendhdr=""; _hasitem=0
    for _j in $(seq 0 $((_na - 1))); do
      if [ "${_ak[$_j]}" = H ]; then _pendhdr=${_av[$_j]}; _hasitem=0; continue; fi
      _dv=${_av[$_j]}
      case "$_dv" in *"$_lc"*) : ;; *) continue ;; esac
      if [ -n "$_pendhdr" ] && [ "$_hasitem" = 0 ]; then _rk[${#_rk[@]}]=H; _rv[${#_rv[@]}]=$_pendhdr; _hasitem=1; fi
      _rk[${#_rk[@]}]=I; _rv[${#_rv[@]}]=$_dv; _mn=$((_mn + 1))
    done
    _nr=${#_rk[@]}
    if [ "$_seeded" = 0 ]; then _seeded=1
      if [ "$_mode" = one ] && [ -n "$_preset" ]; then
        for _i in $(seq 0 $((_nr - 1))); do [ "${_rk[$_i]}" = I ] && [ "${_rv[$_i]}" = "$_preset" ] && { _cur=$_i; break; }; done
      fi
    fi
    [ "$_cur" -ge "$_nr" ] && _cur=$(( _nr > 0 ? _nr - 1 : 0 )); [ "$_cur" -lt 0 ] && _cur=0
    _snap=$_cur; while [ "$_snap" -lt "$_nr" ] && [ "${_rk[$_snap]:-}" = H ]; do _snap=$((_snap + 1)); done
    if [ "$_snap" -ge "$_nr" ]; then _snap=$_cur; while [ "$_snap" -ge 0 ] && [ "${_rk[$_snap]:-H}" = H ]; do _snap=$((_snap - 1)); done; fi
    [ "$_snap" -ge 0 ] && _cur=$_snap
    [ "$_cur" -lt "$_start" ] && _start=$_cur
    [ "$_cur" -ge $((_start + _win)) ] && _start=$((_cur - _win + 1)); [ "$_start" -lt 0 ] && _start=0
    if [ $_first = 0 ]; then printf '\033[%dA' $((_win + 2)); fi
    _first=0
    printf '  %ssearch:%s %s%s\n' "$C_CYAN" "$C_RESET" "$_query" "$EOL"
    for _r in $(seq 0 $((_win - 1))); do
      _i=$((_start + _r))
      if [ "$_i" -ge "$_nr" ]; then printf '%s\n' "$EOL"; continue; fi
      if [ "${_rk[$_i]}" = H ]; then printf '  %s%s%s%s\n' "$C_BOLD$C_YELLOW" "${_rv[$_i]}" "$C_RESET" "$EOL"; continue; fi
      _dv=${_rv[$_i]}; _mk=""
      [ "$_mode" = multi ] && { case "$_selset" in *" $_dv "*) _mk="[x] " ;; *) _mk="[ ] " ;; esac; }
      if [ "$_i" = "$_cur" ]; then printf '     %s%s %s%s %s%s\n' "$C_INV" "$ARROW" "$_mk" "$_dv" "$C_RESET" "$EOL"
      else printf '       %s%s%s\n' "$_mk" "$_dv" "$EOL"; fi
    done
    if [ "$_mode" = multi ]; then
      _out=$(printf '%s' "$_selset" | sed 's/^ *//;s/ *$//')
      printf '    %sselected: %s%s%s\n' "$C_DIM" "${_out:-none}" "$C_RESET" "$EOL"
    else
      printf '    %s%d match(es)%s%s\n' "$C_DIM" "$_mn" "$C_RESET" "$EOL"
    fi
    IFS= read -rsn1 _key || _key=''
    case "$_key" in
      '')
        if [ "$_mode" = one ]; then
          [ "$_mn" -gt 0 ] && [ "${_rk[$_cur]:-}" = I ] && { eval "$_var=\"\${_rv[\$_cur]}\""; break; }
        else
          _out=$(printf '%s' "$_selset" | sed 's/^ *//;s/ *$//'); eval "$_var=\"\$_out\""; break
        fi ;;
      ' ')
        if [ "$_mode" = multi ] && [ "${_rk[$_cur]:-}" = I ]; then
          _dv=${_rv[$_cur]}
          case "$_selset" in *" $_dv "*) _selset=$(printf '%s' "$_selset" | sed "s/ $_dv / /") ;; *) _selset="$_selset$_dv " ;; esac
        fi ;;
      "$ESC") read -rsn2 -t 1 _key || _key=''
        case "$_key" in
          '[A') _p2=$((_cur - 1)); while [ "$_p2" -ge 0 ] && [ "${_rk[$_p2]}" = H ]; do _p2=$((_p2 - 1)); done; [ "$_p2" -ge 0 ] && _cur=$_p2 ;;
          '[B') _p2=$((_cur + 1)); while [ "$_p2" -lt "$_nr" ] && [ "${_rk[$_p2]}" = H ]; do _p2=$((_p2 + 1)); done; [ "$_p2" -lt "$_nr" ] && _cur=$_p2 ;;
        esac ;;
      "$BS"|"$DEL") _query=${_query%?}; _cur=0; _start=0 ;;
      [[:print:]]) _query="$_query$_key"; _cur=0; _start=0 ;;
    esac
  done
  printf '\033[?25h'
}

# --- row generators for the menus -------------------------------------------
project_rows() {
  local _x
  printf 'H|Frameworks\n';        for _x in $(projects_framework); do printf 'I|%s\n' "$_x"; done
  printf 'H|CMS\n';               for _x in $(projects_cms);       do printf 'I|%s\n' "$_x"; done
  printf 'H|E-commerce\n';        for _x in $(projects_ecommerce); do printf 'I|%s\n' "$_x"; done
  printf 'H|Apps\n';              for _x in $(projects_app);       do printf 'I|%s\n' "$_x"; done
  printf 'H|Plain PHP / other\n'; printf 'I|php\n'
}
flat_rows() { local _x; for _x in $1; do printf 'I|%s\n' "$_x"; done; }
php_rows()   { flat_rows "8.5 8.4 8.3 8.2 8.1 8.0 7.4 7.3 7.2 7.1 7.0 5.6"; }
runtime_rows() { flat_rows "php-fpm roadrunner"; }
ws_rows()    { flat_rows "nginx apache2 caddy openresty frankenphp tomcat none"; }
db_rows()    { flat_rows "mysql postgres mariadb mongo mssql percona pgvector postgres-postgis neo4j couchdb rethinkdb cassandra clickhouse tarantool arangodb surrealdb none"; }
cache_rows() { flat_rows "redis valkey dragonfly memcached aerospike varnish ssdb none"; }
_in_rows()   { case " $($1 | sed 's/^I|//' | tr '\n' ' ') " in *" $2 "*) return 0 ;; esac; return 1; }
# Seed the answers from the stack already in .env, so re-running setup shows what you
# actually run instead of starting from scratch. Without this the review screen reports
# "Extra services (none)" while you have three running, and applying silently drops them
# (same for a non-default web server, database or cache). Inverse of how LARADOCK_SERVICES
# is assembled below: web server + runtime + database + cache + extras + workspace.
seed_from_env() {
  local _t _s
  _s=$(env_get LARADOCK_SERVICES | tr -d '"')
  [ -z "$_s" ] && return 0
  for _t in $_s; do
    [ "$_t" = workspace ] && continue
    if   _in_rows ws_rows      "$_t"; then W_WS="$_t"
    elif _in_rows runtime_rows "$_t"; then W_RUNTIME="$_t"
    elif _in_rows db_rows      "$_t"; then W_DB="$_t"
    elif _in_rows cache_rows   "$_t"; then W_CACHE="$_t"
    else W_EXTRAS="${W_EXTRAS:+$W_EXTRAS }$_t"
    fi
  done
}
# --- workspace tools ---------------------------------------------------------
# The workspace (your dev shell) ships a few tools on by default and ~80 more behind
# WORKSPACE_INSTALL_* flags. These groups only decide how the picker is laid out; the
# tool list itself is read from workspace/defaults.env, so a tool added there shows up
# on its own (under "Other" until it's grouped here).
ws_tool_groups() {
  cat <<'WSTOOLS'
Debug & testing|xdebug pcov phpdbg dusk-deps taint
Node & frontend|node yarn pnpm npm-gulp npm-vue-cli npm-angular-cli npm-bower npm-check-updates-cli
Database clients & drivers|mysql-client pg-client mongo mssql oci8 cassandra aerospike ssdb rdkafka zookeeper
PHP extensions|phpredis memcached apcu amqp gearman event swoole soap gnupg gmp bz2 imap ldap mailparse phpdecimal ssh2 xmlrpc xsl yaml zmq trader xlswriter v8js phalcon ast ioncube
Framework CLIs|laravel-installer laravel-envoy symfony deployer drush drupal-console wp-cli prestissimo
Media & documents|imagemagick libpng ffmpeg audiowaveform image-optimizers wkhtmltopdf poppler-utils graphviz
Shell & tools|git-prompt powerline mc lnav linuxbrew gnu-parallel fswatch inotify ping dnsutils sshpass subversion smb supervisor
DevOps|docker-client terraform github-cli protoc workspace-ssh
Other languages|python python3 jdk
WSTOOLS
}
ws_tool_key()  { printf 'WORKSPACE_INSTALL_%s' "$(printf '%s' "$1" | tr 'a-z-' 'A-Z_')"; }
ws_all_tools() { sed -n 's/^WORKSPACE_INSTALL_\([A-Z0-9_]*\)=.*/\1/p' workspace/defaults.env | tr 'A-Z_' 'a-z-'; }
ws_tool_default() {  # ws_tool_default <tool> -> true|false, as shipped
  case "$(env_get "$(ws_tool_key "$1")" workspace/defaults.env)" in true*) printf 'true' ;; *) printf 'false' ;; esac
}
ws_tools_on() {  # tools switched on right now: your .env override, else the shipped default
  local _x _v
  for _x in $(ws_all_tools); do
    _v=$(env_get "$(ws_tool_key "$_x")" .env); [ -n "$_v" ] || _v=$(ws_tool_default "$_x")
    case "$_v" in true*) printf '%s ' "$_x" ;; esac
  done
}

ws_tool_rows() {
  local _label _items _x _cat _rest=""
  _cat=" $(ws_tool_groups | sed 's/^[^|]*|//' | tr '\n' ' ') "
  ws_tool_groups | while IFS='|' read -r _label _items; do
    printf 'H|%s\n' "$_label"; for _x in $_items; do printf 'I|%s\n' "$_x"; done
  done
  for _x in $(ws_all_tools); do
    case "$_cat" in *" $_x "*) : ;; *) _rest="$_rest $_x" ;; esac
  done
  [ -n "$_rest" ] && { printf 'H|Other\n'; for _x in $_rest; do printf 'I|%s\n' "$_x"; done; }
  return 0
}

extra_service_rows() {  # every non-essential service, grouped (web/db/cache handled separately)
  local _label _items _x _o
  service_groups | while IFS='|' read -r _label _items; do
    case "$_label" in "Web servers"|"Databases"|"Cache") continue ;; esac
    printf 'H|%s\n' "$_label"; for _x in $_items; do printf 'I|%s\n' "$_x"; done
  done
  _o=$(service_other)
  [ -n "$_o" ] && { printf 'H|Other\n'; for _x in $_o; do printf 'I|%s\n' "$_x"; done; }
}

# --- single-question helpers (each re-askable from the review screen) --------
# Each passes a short plain-English HELP line so a first-timer knows what they're
# choosing and why the pre-selected default is a safe bet.
ask_type()    { STEP_N=1; imenu one W_TYPE "What are you building?" project_rows "${W_TYPE:-$fw_item_def}" \
  "Laradock tunes the rest of the setup around this: your framework decides which\n  web server, database and tools get pre-selected for you.\n  ${C_DIM}Pick \"php\" for a plain PHP app, or anything not in the list.${C_RESET}"; W_CAT=$(category_of "$W_TYPE"); }
ask_php()     { STEP_N=2; imenu one W_PHP "PHP version" php_rows "${W_PHP:-$(default_of PHP_VERSION 8.4)}" \
  "The version of PHP your code runs on, the same number you'd see in \`php -v\`.\n  ${C_DIM}Newer is faster. 8.4 suits most apps. Pick an older one only if your app\n  or a package needs it (legacy client, old Laravel).${C_RESET}"; }
ask_runtime() { STEP_N=3; imenu one W_RUNTIME "PHP runtime" runtime_rows "${W_RUNTIME:-php-fpm}" \
  "The program that actually executes your PHP when a request comes in, sitting\n  behind the web server.\n  ${C_DIM}php-fpm is the standard, boring, correct answer. Only take roadrunner if you\n  already know you want a long-running worker.${C_RESET}"; }
ask_ws()      { STEP_N=4; imenu one W_WS "Web server" ws_rows "${W_WS:-$(ws_default_for "$W_CAT" "$W_TYPE")}" \
  "Answers http://localhost in your browser and hands PHP requests to the runtime.\n  ${C_DIM}nginx is the common pick. Choose apache2 if your app ships .htaccess rules\n  (lots of WordPress setups do). \"none\" = CLI-only, no website.${C_RESET}"; }
ask_db()      { STEP_N=5; imenu one W_DB "Database" db_rows "${W_DB:-$(db_default_for "$W_TYPE")}" \
  "Where your app keeps its data: users, posts, orders. Laradock runs it for you\n  and can write the connection details into your app's .env.\n  ${C_DIM}mysql is the safe default. \"none\" if your app has no database yet.${C_RESET}"; }
ask_cache()   { STEP_N=6; imenu one W_CACHE "Cache" cache_rows "${W_CACHE:-redis}" \
  "An in-memory store your app uses for sessions, queues and caching, so it isn't\n  hitting the database for everything.\n  ${C_DIM}redis is the standard pick. \"none\" is fine if you don't need one yet.${C_RESET}"; }
ask_extras()  { STEP_N=7; imenu multi W_EXTRAS "Extra services" extra_service_rows "${W_EXTRAS:-$(rec_extras_for "$W_TYPE")}" \
  "Extra containers to run alongside your app: mail catchers, search engines,\n  queues, database UIs. Each one you tick is a container that starts with your stack.\n  ${C_DIM}What your project usually needs is already ticked. Nothing here is permanent,\n  add one later with ./laradock start <name>.${C_RESET}"; }
ask_tools()   { STEP_N=8; imenu multi W_TOOLS "Workspace tools" ws_tool_rows "${W_TOOLS:-$(ws_tools_on)}" \
  "The workspace is your dev shell: the container you run php, composer, artisan,\n  npm and git inside (./laradock workspace). These are the tools baked into it.\n  ${C_DIM}Already ticked = what you have today. Common adds: xdebug (step debugging),\n  mysql-client (a db shell), wp-cli (WordPress). Changing these rebuilds the\n  workspace image, which takes a few minutes.${C_RESET}"; }
ask_name()   { STEP_N=9;  step_header "Project name" \
  "Names your containers and keeps this project's data separate from your other\n  Laradock projects.\n  ${C_DIM}Docker only allows lowercase letters, numbers, - and _ here.${C_RESET}"
  ask W_NAME "Project name" "${W_NAME:-$name_def}"
  local _clean; _clean=$(sanitize_project_name "$W_NAME")
  [ "$_clean" = "$W_NAME" ] || { note "docker won't take \"$W_NAME\", using ${C_CYAN}${_clean}${C_RESET} instead."; W_NAME=$_clean; }; }
ask_path()   { STEP_N=10; step_header "App path" \
  "Where your code lives on this machine, relative to this folder. Laradock mounts\n  it into the containers, so edits on your laptop are live in the stack.\n  ${C_DIM}\"../\" means the folder next to laradock/, the usual layout.${C_RESET}"; ask W_PATH "App path" "${W_PATH:-$app_path}"; }

# patch_app_env app_path db cache extras — diff + confirm + backup + markers
patch_app_env() {
  local _app=$1 _db=$2 _cache=$3 _extras=$4 _envf="$1/.env"
  [ -f "$_envf" ] || { [ -f "$_app/.env.example" ] && confirm "App has no .env; create it from .env.example?" Y \
      && cp "$_app/.env.example" "$_envf" && ok "created app .env"; }
  [ -f "$_envf" ] || return 0

  # build proposed replacements: key -> value
  local keys=() vals=()
  case "$_db" in
    mysql|mariadb) keys+=(DB_CONNECTION DB_HOST DB_PORT DB_DATABASE DB_USERNAME DB_PASSWORD)
                   vals+=(mysql "$_db" 3306 default default secret) ;;
    postgres)      keys+=(DB_CONNECTION DB_HOST DB_PORT DB_DATABASE DB_USERNAME DB_PASSWORD)
                   vals+=(pgsql postgres 5432 default default secret) ;;
  esac
  case "$_cache" in
    redis|valkey)  keys+=(REDIS_HOST);     vals+=("$_cache") ;;
    memcached)     keys+=(MEMCACHED_HOST); vals+=(memcached) ;;
  esac
  case " $_extras " in *" mailpit "*) keys+=(MAIL_MAILER MAIL_HOST MAIL_PORT); vals+=(smtp mailpit 1025) ;; esac
  [ ${#keys[@]} -gt 0 ] || return 0

  # compute the actual diff (only keys that exist with a different value, or are missing)
  local i changes=()
  for i in $(seq 0 $(( ${#keys[@]} - 1 ))); do
    local k=${keys[$i]} v=${vals[$i]} cur
    cur=$(env_get "$k" "$_envf")
    # respect the marker contract: if we set it before and user changed it since, leave it alone
    if grep -q "^${k}=.* # set by laradock" "$_envf" 2>/dev/null; then
      local marked; marked=$(sed -n "s/^${k}=\(.*\) # set by laradock.*/\1/p" "$_envf" | tail -1)
      [ "$marked" != "$v" ] && continue
    fi
    [ "$cur" = "$v" ] && continue
    changes+=("$k|$cur|$v")
  done
  [ ${#changes[@]} -gt 0 ] || { ok "app .env already points at these services"; return 0; }

  say ""
  bold "  Point your app's .env at these services?"
  for c in "${changes[@]}"; do
    local k rest cur v
    k=${c%%|*}; rest=${c#*|}; cur=${rest%%|*}; v=${rest#*|}
    if [ -n "$cur" ]; then say "    $k=$cur  $ARROW  $k=$v"
    else                   say "    + $k=$v"; fi
  done
  if confirm "Apply (original backed up to .env.bak.laradock)?" Y; then
    cp "$_envf" "$_envf.bak.laradock"
    for c in "${changes[@]}"; do
      local k rest v
      k=${c%%|*}; rest=${c#*|}; v=${rest#*|}
      if grep -q "^${k}=" "$_envf"; then
        sed "s|^${k}=.*|${k}=${v} # set by laradock|" "$_envf" > "$_envf.tmp.$$" && mv "$_envf.tmp.$$" "$_envf"
      elif grep -q "^# *${k}=" "$_envf"; then
        sed "s|^# *${k}=.*|${k}=${v} # set by laradock|" "$_envf" > "$_envf.tmp.$$" && mv "$_envf.tmp.$$" "$_envf"
      else
        printf '%s=%s # set by laradock\n' "$k" "$v" >> "$_envf"
      fi
    done
    ok "app .env updated (backup: .env.bak.laradock)"
  else
    say "    skipped; set them yourself when ready"
  fi
}

# ----------------------------------------------------------------- cmd: up

cmd_up() {
  require_laradock_dir
  check_docker
  # `start nginx mysql` (explicit services) skips setup, so ensure .env exists here too.
  [ -f .env ] || { [ -f .env.example ] && cp .env.example .env && ok "created .env from .env.example"; }
  local services=("$@")
  # Explicit services on the command line (`up nginx mysql`) skip the setup check.
  if [ ${#services[@]} -eq 0 ]; then
    # No setup yet = no .env, or an .env the wizard never wrote LARADOCK_SERVICES into.
    local s=""
    [ -f .env ] && s=$(env_get LARADOCK_SERVICES | tr -d '"')
    if [ -z "$s" ]; then
      if confirm "No setup found. Run ./laradock setup now?" Y; then
        SKIP_START_OFFER=1; cmd_setup; unset SKIP_START_OFFER   # we start below, don't double-start
        s=$(env_get LARADOCK_SERVICES | tr -d '"')
        [ -n "$s" ] || exit 0   # setup declined to write / user quit
      else
        die "Nothing to start yet: this project hasn't been set up." \
            "${C_DIM}Run${C_RESET} ${C_CYAN}./laradock setup${C_RESET} ${C_DIM}first (takes a minute, all answers pre-filled),${C_RESET}" \
            "${C_DIM}or name services directly:${C_RESET} ${C_CYAN}./laradock start nginx mysql${C_RESET}"
      fi
    fi
    # shellcheck disable=SC2206
    services=($s)
  fi
  bold ""
  bold "  Starting: ${services[*]}"
  local rc _tmp
  _tmp="${TMPDIR:-/tmp}/laradock-up.$$"
  printf '  %s%s docker compose up -d %s%s\n' "$C_DIM" "$ARROW" "${services[*]}" "$C_RESET"
  docker compose up -d "${services[@]}" 2>&1 | tee "$_tmp"
  rc=${PIPESTATUS[0]}
  if [ $rc -ne 0 ]; then
    if grep -qi 'port is already allocated\|address already in use' "$_tmp"; then
      local port svc var owner sugg
      port=$(grep -oE 'Bind for [0-9.:]+[0-9]+' "$_tmp" | grep -oE '[0-9]+$' | head -1)
      # Name the exact variable when we can: compose names the failing endpoint
      # <project>-<service>-N; the service folder's defaults.env holds the port var.
      svc=$(grep -oE 'endpoint [A-Za-z0-9_-]+' "$_tmp" | head -1 | awk '{print $2}')
      svc=${svc%-[0-9]*}; svc=${svc#"$(env_get COMPOSE_PROJECT_NAME | tr -d '"')"-}
      var=""
      [ -n "$svc" ] && [ -n "$port" ] && [ -f "$svc/defaults.env" ] \
        && var=$(grep -E "^[A-Z0-9_]*PORT[A-Z0-9_]*=${port}\$" "$svc/defaults.env" | head -1 | cut -d= -f1)
      # who is holding the port (best effort, macOS/Linux)
      owner=""
      [ -n "$port" ] && command -v lsof >/dev/null 2>&1 \
        && owner=$(lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | awk 'NR==2 {print $1" (pid "$2")"}')
      # suggest a replacement port that is actually free right now
      sugg=""
      if [ -n "$port" ]; then
        local _c=$((port + 10000))
        while [ "$_c" -lt $((port + 10020)) ]; do
          if ! (exec 3<>"/dev/tcp/127.0.0.1/$_c") 2>/dev/null; then sugg=$_c; break; fi
          _c=$((_c + 1))
        done
      fi
      say ""
      bad "${C_BOLD}Port ${port:-?} is busy:${C_RESET} something on your machine is already using it."
      [ -n "$owner" ] && say "     ${C_DIM}(currently held by: ${owner})${C_RESET}"
      say ""
      if [ -n "$var" ] && [ -n "$sugg" ]; then
        say "     No problem: ${C_BOLD}${svc}${C_RESET} just needs a different port. ${sugg} is free."
        say ""
        if confirm "Fix it for you? (writes ${var}=${sugg} to laradock/.env, then starts again)" Y; then
          env_set "$var" "$sugg"
          ok "set ${var}=${sugg} in .env"
          rm -f "$_tmp"
          cmd_up "${services[@]}"
          exit $?
        fi
        say ""
        say "     To do it yourself later:  ${C_CYAN}./laradock set ${var}=${sugg}${C_RESET}  ${C_DIM}then${C_RESET}  ${C_CYAN}./laradock start${C_RESET}"
      elif [ -n "$var" ]; then
        say "     No problem: ${C_BOLD}${svc}${C_RESET} just needs a different port. Two steps:"
        say ""
        say "       1. Pick a free port and run:   ${C_CYAN}./laradock set ${var}=<a free port>${C_RESET}"
        say "       2. Run this again:             ${C_CYAN}./laradock start${C_RESET}"
      else
        say "     No problem: point that service at a different port. Two steps:"
        say ""
        say "       1. Override its port, e.g.:  ${C_CYAN}./laradock set MYSQL_PORT=3307${C_RESET}  ${C_DIM}(each service lists its"
        say "          port variable in its own defaults.env: MYSQL_PORT, REDIS_PORT, NGINX_HOST_HTTP_PORT, ...)${C_RESET}"
        say "       2. Run this again:            ${C_CYAN}./laradock start${C_RESET}"
      fi
      say ""
    else
      say ""
      bad "${C_BOLD}Docker could not start your services.${C_RESET} The full output is above."
      say "     ${C_DIM}The last few lines usually say why. For a quick health check, run:${C_RESET} ${C_CYAN}./laradock doctor${C_RESET}"
      say ""
    fi
    rm -f "$_tmp"
    exit $rc
  fi
  rm -f "$_tmp"
  cmd_info
}

# ---------------------------------------------------------------- cmd: set

svc_of_key() {  # best-effort: which service folder owns this variable
  local _k=$1 _p
  case "$_k" in PHP_VERSION) printf 'php-fpm'; return ;; esac
  _p=$(printf '%s' "$_k" | cut -d_ -f1 | tr '[:upper:]' '[:lower:]')
  [ -f "$_p/defaults.env" ] && { printf '%s' "$_p"; return; }
  grep -l "^${_k}=" ./*/defaults.env 2>/dev/null | head -1 | sed 's|^\./||; s|/defaults.env$||'
}

default_value_of() {  # shipped default: any defaults.env first, else .env.example
  local _d
  _d=$(grep -h "^${1}=" ./*/defaults.env 2>/dev/null | head -1 | cut -d= -f2-)
  [ -n "$_d" ] || _d=$(env_get "$1" .env.example)
  printf '%s' "$_d"
}

# Some settings are compiled into the image (the WORKSPACE_INSTALL_* tools, PHP_VERSION,
# any *_VERSION): changing one does nothing until the image is rebuilt, and a restart
# silently keeps the old one. Both `set` and `unset` ask this, so they can't disagree
# about what a user has to do next.
is_build_time_key() {
  case "$1" in PHP_VERSION|INSTALL_*|*_INSTALL_*|*_VERSION) return 0 ;; esac
  return 1
}

cmd_set() {  # set KEY=VALUE [KEY=VALUE ...] — write overrides into laradock/.env
  require_laradock_dir
  [ $# -gt 0 ] || die "What do you want to set?" \
      "${C_DIM}Example:${C_RESET} ${C_CYAN}./laradock set REDIS_PORT=16379${C_RESET} ${C_DIM}(browse what exists: ./laradock settings mysql)${C_RESET}"
  [ -f .env ] || { [ -f .env.example ] && cp .env.example .env && ok "created .env from .env.example"; }
  local kv k v svc _data
  for kv in "$@"; do
    case "$kv" in
      [A-Za-z_]*=*) ;;
      *) die "Settings look like KEY=VALUE." \
             "${C_DIM}Example:${C_RESET} ${C_CYAN}./laradock set REDIS_PORT=16379${C_RESET}" ;;
    esac
    k=${kv%%=*}; v=${kv#*=}
    env_set "$k" "$v"
    ok "set ${k}=${v} in .env"
    svc=$(svc_of_key "$k")
    # honest heads-up: database passwords only apply to a fresh database
    case "$k" in
      MYSQL_*PASSWORD|MARIADB_*PASSWORD|PERCONA_*PASSWORD|POSTGRES_PASSWORD|MONGO_*PASSWORD|MSSQL_*PASSWORD)
        _data=$(default_of DATA_PATH_HOST "$HOME/.laradock/data"); _data=${_data/#\~/$HOME}
        if [ -n "$svc" ] && [ -d "${_data}/${svc}" ]; then
          note "your ${svc} database already has data, so it keeps its OLD password (these apply on first boot only)."
          say  "     ${C_DIM}Change it inside the database instead (ALTER USER, see the ${svc} docs page),${C_RESET}"
          say  "     ${C_DIM}or start that database fresh by deleting ${_data}/${svc} (erases its data).${C_RESET}"
          continue
        fi ;;
    esac
    # help apply it: build-time settings need a rebuild, the rest just a restart
    case "$k" in
      PHP_VERSION|INSTALL_*|*_INSTALL_*|*_VERSION)
        say "  ${C_DIM}This is baked into the image. Apply it with:${C_RESET} ${C_CYAN}./laradock rebuild ${svc:-workspace}${C_RESET}" ;;
      *)
        if [ -n "$svc" ] && docker compose ps --services --status running 2>/dev/null | grep -qx "$svc"; then
          if confirm "Restart ${svc} now so it takes effect?" Y; then run up -d "$svc"; fi
        else
          say "  ${C_DIM}Takes effect the next time ${svc:-that service} starts.${C_RESET}"
        fi ;;
    esac
  done
}

# ----------------------------------------------------------- cmd: settings

cmd_settings() {  # settings [service] — read side of `set`
  require_laradock_dir
  local k v d line
  if [ -n "${1:-}" ]; then
    [ -f "$1/defaults.env" ] || die "No service called '$1'." \
        "${C_DIM}The service name is its folder name: mysql, nginx, redis, workspace, ...${C_RESET}"
    bold ""
    bold "  $1 — every setting you can change  ${C_DIM}(./laradock set KEY=VALUE)${C_RESET}"
    say  "  ─────────────────────────────────────────────"
    while IFS= read -r line; do
      case "$line" in ''|\#*) continue ;; esac
      k=${line%%=*}; d=${line#*=}
      v=$(env_get "$k")
      if [ -n "$v" ] && [ "$v" != "$d" ]; then
        printf '  %-36s = %s%s%s   %s(you changed it; default: %s)%s\n' "$k" "$C_CYAN" "$v" "$C_RESET" "$C_DIM" "$d" "$C_RESET"
      else
        printf '  %-36s = %s\n' "$k" "$d"
      fi
    done < "$1/defaults.env"
    say ""
  else
    bold ""
    bold "  Your customizations  ${C_DIM}(.env values that differ from the shipped defaults)${C_RESET}"
    say  "  ─────────────────────────────────────────────"
    local found=0
    [ -f .env ] || { note "no .env yet. Run ./laradock setup first."; return; }
    while IFS= read -r line; do
      case "$line" in ''|\#*) continue ;; esac
      k=${line%%=*}; v=${line#*=}; v=${v%% # set by laradock*}
      d=$(default_value_of "$k")
      if [ -n "$d" ] && [ "$v" != "$d" ]; then
        printf '  %-36s = %s%s%s   %s(default: %s)%s\n' "$k" "$C_CYAN" "$v" "$C_RESET" "$C_DIM" "$d" "$C_RESET"
        found=1
      fi
    done < .env
    [ "$found" = 1 ] || say "  (none yet — everything is on its shipped default)"
    say ""
    say "  ${C_DIM}Browse a service's settings: ./laradock settings mysql · change one: ./laradock set KEY=VALUE${C_RESET}"
    say ""
  fi
}

# -------------------------------------------------------------- cmd: unset

cmd_unset() {  # unset KEY [KEY ...] — remove your override, back to the default
  require_laradock_dir
  [ $# -gt 0 ] || die "Which setting do you want back on its default?" \
      "${C_DIM}Example:${C_RESET} ${C_CYAN}./laradock unset REDIS_PORT${C_RESET} ${C_DIM}(see your changes: ./laradock settings)${C_RESET}"
  local k d changed=0 rebuild=""
  for k in "$@"; do
    if ! grep -q "^${k}=" .env 2>/dev/null; then
      note "${k} is not set in your .env; nothing to undo."
      continue
    fi
    changed=1
    is_build_time_key "$k" && rebuild="${rebuild:+$rebuild }$(svc_of_key "$k")"
    d=$(grep -h "^${k}=" ./*/defaults.env 2>/dev/null | head -1 | cut -d= -f2-)
    if [ -n "$d" ]; then
      # a service default exists: safe to drop the override entirely
      sed "/^${k}=/d" .env > .env.tmp.$$ && mv .env.tmp.$$ .env
      ok "${k} back to its default (${d})"
    elif [ -n "$(env_get "$k" .env.example)" ]; then
      # shared setting compose needs: reset to the shipped value instead of deleting
      env_set "$k" "$(env_get "$k" .env.example)"
      ok "${k} reset to the shipped value ($(env_get "$k" .env.example))"
    else
      sed "/^${k}=/d" .env > .env.tmp.$$ && mv .env.tmp.$$ .env
      ok "removed ${k} from .env"
    fi
  done
  [ "$changed" = 0 ] && return
  if [ -n "$rebuild" ]; then
    # removing a tool means rebuilding the image without it; a restart would keep it
    rebuild=$(printf '%s\n' $rebuild | sort -u | tr '\n' ' ' | sed 's/ *$//')
    say "  ${C_DIM}This is baked into the image. Apply it with:${C_RESET} ${C_CYAN}./laradock rebuild ${rebuild:-workspace}${C_RESET}"
  else
    say "  ${C_DIM}Takes effect the next time the affected service starts.${C_RESET}"
  fi
}

# --------------------------------------------------------------- cmd: edit

cmd_edit() {  # edit            -> your .env
              # edit <service>  -> that service's Dockerfile
              # edit <service> <file> -> any file in that service's folder (compose.yml, my.cnf, ...)
  require_laradock_dir
  local target hint=""
  if [ -z "${1:-}" ]; then
    [ -f .env ] || { [ -f .env.example ] && cp .env.example .env && ok "created .env from .env.example"; }
    target=.env
  else
    [ -d "$1" ] || die "No service called '$1'." \
        "${C_DIM}The service name is its folder name: mysql, nginx, redis, workspace, ...${C_RESET}"
    if [ -n "${2:-}" ]; then
      [ -f "$1/$2" ] || die "No file '$2' in ${1}/." \
          "${C_DIM}It has:${C_RESET} $(cd "$1" && ls -p | grep -v / | tr '\n' ' ')"
      target="$1/$2"
    else
      target="$1/Dockerfile"
      [ -f "$target" ] || die "${1} has no Dockerfile." \
          "${C_DIM}Edit a specific file instead:${C_RESET} ${C_CYAN}./laradock edit $1 compose.yml${C_RESET}"
    fi
    case "$target" in
      */Dockerfile) hint="Apply your change with: ${C_CYAN}./laradock rebuild $1${C_RESET}" ;;
      */compose.yml) hint="Apply your change with: ${C_CYAN}./laradock start $1${C_RESET} ${C_DIM}(recreates the container)${C_RESET}" ;;
      */defaults.env) hint="${C_DIM}Tip: don't edit defaults; override instead with${C_RESET} ${C_CYAN}./laradock set KEY=VALUE${C_RESET}" ;;
    esac
  fi
  "${EDITOR:-${VISUAL:-vi}}" "$target"
  [ -z "$hint" ] || say "  $hint"
}

# --------------------------------------------------------------- cmd: info

cmd_info() {
  require_laradock_dir
  bold ""
  bold "  Laradock — $(env_get COMPOSE_PROJECT_NAME | tr -d '"')"
  say  "  ─────────────────────────────────────────────"
  printf '  %s%s docker compose ps%s\n' "$C_DIM" "$ARROW" "$C_RESET"
  docker compose ps --format '  {{.Service}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null \
    | awk -F'\t' '{printf "  %-18s %-25s %s\n", $1, $2, $3}'
  local running; running=$(docker compose ps --services 2>/dev/null)
  say ""
  bold "  URLs & credentials:"
  case "$running" in *nginx*|*apache2*|*caddy*)
    local _hp; _hp=$(default_of NGINX_HOST_HTTP_PORT 80)
    if [ "$_hp" = 80 ]; then say "    App          http://localhost"
    else say "    App          http://localhost:$_hp"; fi ;; esac
  case "$running" in *phpmyadmin*) say "    phpMyAdmin   http://localhost:$(default_of PMA_PORT 8081)  (server: mysql, user: default, pass: secret)" ;; esac
  case "$running" in *adminer*)    say "    Adminer      http://localhost:$(default_of ADM_PORT 8080)" ;; esac
  case "$running" in *mailpit*)    say "    Mailpit      http://localhost:$(default_of MAILPIT_HTTP_PORT 8125)" ;; esac
  case "$running" in *open-webui*) say "    Open WebUI   http://localhost:$(default_of OPEN_WEBUI_PORT 8322)" ;; esac
  case "$running" in *mysql*)      say "    MySQL        localhost:$(default_of MYSQL_PORT 3306)  db: $(default_of MYSQL_DATABASE default)  user: $(default_of MYSQL_USER default)  pass: $(default_of MYSQL_PASSWORD secret) (root: $(default_of MYSQL_ROOT_PASSWORD root))" ;; esac
  case "$running" in *postgres*)   say "    Postgres     localhost:$(default_of POSTGRES_PORT 5432)  db: $(default_of POSTGRES_DB default)  user: $(default_of POSTGRES_USER default)  pass: $(default_of POSTGRES_PASSWORD secret)" ;; esac
  case "$running" in *redis*)      say "    Redis        localhost:$(default_of REDIS_PORT 6379)  pass: $(default_of REDIS_PASSWORD secret_redis)" ;; esac
  say ""
  local _dbhost=mysql
  case "$running" in *mysql*) _dbhost=mysql ;; *postgres*) _dbhost=postgres ;; *mariadb*) _dbhost=mariadb ;; esac
  bold "  Inside your app, reach services by NAME (DB_HOST=${_dbhost}, REDIS_HOST=redis)."
  bold "  Next:  ./laradock workspace     (dev shell: php, composer, node, git)"
  say  "  ${C_DIM}Add or drop services (mail, search, AI, phpMyAdmin...):${C_RESET} ${C_CYAN}./laradock setup${C_RESET}"
  say ""
}

# -------------------------------------------------------------- cmd: shell

cmd_workspace() {
  require_laradock_dir
  check_docker
  if ! docker compose ps --services 2>/dev/null | grep -qx workspace; then
    if confirm "workspace is not running. Start it?" Y; then
      run up -d workspace || exit $?
    else
      exit 1
    fi
  fi
  local user_flag=()
  [ "${1:-}" = "--root" ] || user_flag=(-u laradock)
  printf '  %s%s docker compose exec %s workspace bash%s\n' "$C_DIM" "$ARROW" "${user_flag[*]:-}" "$C_RESET"
  exec docker compose exec "${user_flag[@]}" workspace bash
}

# -------------------------------------------------------------- cmd: enter
# Open a terminal inside any container without the user knowing `exec`/`bash`.
cmd_enter() {
  require_laradock_dir
  check_docker
  local svc=${1:-}
  [ -n "$svc" ] || die "Which service do you want a terminal in?" \
                       "${C_DIM}Example:${C_RESET} ${C_CYAN}./laradock enter mysql${C_RESET}"
  # the workspace has a dedicated command: it lands you as `laradock`, not root,
  # so composer/npm don't leave root-owned files on the host.
  [ "$svc" = workspace ] && { shift; cmd_workspace "$@"; }
  if ! docker compose ps --services --status running 2>/dev/null | grep -qx "$svc"; then
    if confirm "$svc is not running. Start it?" Y; then run up -d "$svc" || exit $?; else exit 1; fi
  fi
  printf '  %s%s docker compose exec %s bash%s\n' "$C_DIM" "$ARROW" "$svc" "$C_RESET"
  # prefer bash, fall back to sh for slim images (mysql, redis, ...)
  exec docker compose exec "$svc" sh -c 'command -v bash >/dev/null 2>&1 && exec bash || exec sh'
}

# start a service (with a prompt) if it isn't already running — used by test/db
ensure_running() {  # ensure_running SERVICE
  local s=$1
  docker compose ps --services --status running 2>/dev/null | grep -qx "$s" && return 0
  if confirm "$s is not running. Start it?" Y; then run up -d "$s" || exit $?; else exit 1; fi
}

# ---------------------------------------------------------------- cmd: test
# Run the app's test suite inside the workspace (artisan test > pest > phpunit).
cmd_test() {
  require_laradock_dir
  check_docker
  ensure_running workspace
  printf '  %s%s docker compose exec -u laradock workspace <artisan|pest|phpunit> test%s\n' "$C_DIM" "$ARROW" "$C_RESET"
  exec docker compose exec -u laradock workspace bash -c '
    if   [ -f artisan ];            then exec php artisan test "$@"
    elif [ -x vendor/bin/pest ];    then exec vendor/bin/pest "$@"
    elif [ -x vendor/bin/phpunit ]; then exec vendor/bin/phpunit "$@"
    else echo "No test runner found (looked for artisan, vendor/bin/pest, vendor/bin/phpunit)."; exit 1; fi
  ' _ "$@"
}

# ---------------------------------------------------------------- cmd: open
# Open the app (or a known web UI) in the default browser — no URL to remember.
cmd_open() {
  require_laradock_dir
  local target=${1:-app} url port
  case "$target" in
    app)
      port=$(default_of NGINX_HOST_HTTP_PORT 80)
      if [ "$port" = 80 ]; then url="http://localhost"; else url="http://localhost:$port"; fi ;;
    mail|mailpit)      url="http://localhost:$(default_of MAILPIT_HTTP_PORT 8125)" ;;
    pma|phpmyadmin)    url="http://localhost:$(default_of PMA_PORT 8081)" ;;
    adminer)           url="http://localhost:$(default_of ADM_PORT 8080)" ;;
    http://*|https://*) url="$target" ;;
    *) die "don't know how to open '$target'" "try: app, mailpit, phpmyadmin, adminer, or a full URL" ;;
  esac
  printf '  %s%s open %s%s\n' "$C_DIM" "$ARROW" "$url" "$C_RESET"
  if   command -v open     >/dev/null 2>&1; then open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$url" >/dev/null 2>&1 &
  elif command -v wslview  >/dev/null 2>&1; then wslview "$url"
  else say "  open this in your browser: $url"; fi
}

# ------------------------------------------------------------------ cmd: db
# Drop into a SQL shell in the running database container (creds handled for you).
cmd_db() {
  require_laradock_dir
  check_docker
  local running; running=$(docker compose ps --services --status running 2>/dev/null)
  case "$running" in
    *mysql*)
      printf '  %s%s docker compose exec mysql mysql%s\n' "$C_DIM" "$ARROW" "$C_RESET"
      exec docker compose exec mysql sh -c 'exec mysql -u"${MYSQL_USER:-default}" -p"${MYSQL_PASSWORD:-secret}" "${MYSQL_DATABASE:-default}"' ;;
    *mariadb*)
      printf '  %s%s docker compose exec mariadb mysql%s\n' "$C_DIM" "$ARROW" "$C_RESET"
      exec docker compose exec mariadb sh -c 'exec mysql -u"${MYSQL_USER:-default}" -p"${MYSQL_PASSWORD:-secret}" "${MYSQL_DATABASE:-default}"' ;;
    *postgres*)
      printf '  %s%s docker compose exec postgres psql%s\n' "$C_DIM" "$ARROW" "$C_RESET"
      exec docker compose exec postgres sh -c 'exec psql -U "${POSTGRES_USER:-default}" "${POSTGRES_DB:-default}"' ;;
    *)
      die "no database is running" "start one first, e.g.: ./laradock start mysql" ;;
  esac
}

# --------------------------------------------------------------- cmd: share
# Expose the local app on a temporary public URL via an installed tunnel tool.
# ponytail: wraps cloudflared/ngrok, don't reinvent tunneling; add expose if asked.
cmd_share() {
  require_laradock_dir
  local port; port=$(default_of NGINX_HOST_HTTP_PORT 80)
  if command -v cloudflared >/dev/null 2>&1; then
    printf '  %s%s cloudflared tunnel --url http://localhost:%s%s\n' "$C_DIM" "$ARROW" "$port" "$C_RESET"
    exec cloudflared tunnel --url "http://localhost:$port"
  elif command -v ngrok >/dev/null 2>&1; then
    printf '  %s%s ngrok http %s%s\n' "$C_DIM" "$ARROW" "$port" "$C_RESET"
    exec ngrok http "$port"
  else
    die "no tunnel tool found (cloudflared or ngrok)" \
        "install one, then retry:" \
        "${C_DIM}cloudflared (no signup):${C_RESET} brew install cloudflared" \
        "${C_DIM}ngrok:${C_RESET} https://ngrok.com/download"
  fi
}

# --------------------------------------------------------------- cmd: ship
# Build (and optionally push) a hardened production image of the user's app.
# The image is the universal deploy artifact — run it anywhere (production/README.md).
cmd_ship() {
  require_laradock_dir
  check_docker
  [ -f production/Dockerfile ] || die "no production/ folder in this laradock" \
     "update laradock to get the production deploy files."

  local push=0 tag="" platform=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --push)        push=1 ;;
      --platform)    shift; platform=${1:-} ;;
      --platform=*)  platform=${1#*=} ;;
      -*)            die "unknown option: $1" "usage: ./laradock ship [image:tag] [--platform os/arch] [--push]" ;;
      *)             tag="$1" ;;
    esac
    shift
  done
  [ -n "$tag" ] || tag="laradock-app:latest"   # matches APP_IMAGE default in production/compose.yml

  # Apple-Silicon guard: most servers & k8s run amd64; an arm64 image fails there ("exec format error").
  if [ -z "$platform" ]; then
    case "$(uname -m)" in
      arm64|aarch64)
        note "you're on arm (Apple Silicon) — most servers & k8s run amd64, so building for linux/amd64"
        say  "     ${C_DIM}force native with${C_RESET} ${C_CYAN}./laradock ship --platform linux/arm64${C_RESET}"
        platform="linux/amd64" ;;
    esac
  fi

  # app code lives where dev mounts it from (APP_CODE_PATH_HOST, default ../)
  local app_rel; app_rel=$(env_get APP_CODE_PATH_HOST); app_rel=${app_rel:-../}
  local app_root
  app_root=$(cd "$app_rel" 2>/dev/null && pwd) ||
    die "can't find your app at: $app_rel" "set APP_CODE_PATH_HOST in .env to your project folder."

  # keep secrets / .git / the laradock stack out of the image
  if [ ! -f "$app_root/.dockerignore" ]; then
    note "no .dockerignore in your app — writing a safe default (keeps secrets & .git out of the image)"
    cp production/dockerignore.sample "$app_root/.dockerignore"
  fi

  bold ""
  bold "  Building production image  ${tag}"
  say  "  ${C_DIM}app: ${app_root}${C_RESET}"
  [ -n "$platform" ] && say "  ${C_DIM}platform: ${platform}${C_RESET}"
  if [ -n "$platform" ]; then
    printf '  %s%s docker build --platform %s -f production/Dockerfile -t %s %s%s\n' \
      "$C_DIM" "$ARROW" "$platform" "$tag" "$app_root" "$C_RESET"
    docker build --platform "$platform" -f "$PWD/production/Dockerfile" -t "$tag" "$app_root" || exit $?
  else
    printf '  %s%s docker build -f production/Dockerfile -t %s %s%s\n' \
      "$C_DIM" "$ARROW" "$tag" "$app_root" "$C_RESET"
    docker build -f "$PWD/production/Dockerfile" -t "$tag" "$app_root" || exit $?
  fi
  local size; size=$(docker image inspect "$tag" --format '{{.Size}}' 2>/dev/null | awk '{printf "%.0fMB", $1/1048576}')
  ok "built  ${tag}${size:+  ($size)}"

  if [ "$push" = 1 ]; then
    printf '  %s%s docker push %s%s\n' "$C_DIM" "$ARROW" "$tag" "$C_RESET"
    docker push "$tag" || exit $?
    ok "pushed  ${tag}"
  fi

  say ""
  say "  ${OK} image ready. Deploy it anywhere that runs a container:"
  say "     ${C_DIM}single server${C_RESET}       APP_IMAGE=${tag} docker compose -f production/compose.yml up -d"
  say "     ${C_DIM}kamal · k8s · paas${C_RESET}  see production/README.md"
}

# ------------------------------------------------------------- cmd: doctor

cmd_doctor() {
  require_laradock_dir
  bold ""
  bold "  Laradock doctor"
  say  "  ─────────────────────────────────────────────"
  local fails=0 warns=0

  if command -v docker >/dev/null 2>&1; then ok "docker installed"; else bad "docker not installed"; fails=$((fails+1)); fi
  if docker info >/dev/null 2>&1; then ok "docker daemon running"; else bad "docker daemon NOT running"; fails=$((fails+1)); fi
  if compose_version_ok; then
    ok "compose v$(compose_version) (needs 2.${MIN_COMPOSE_MINOR}+)"
  else
    bad "compose v$(compose_version) too old or missing (needs 2.${MIN_COMPOSE_MINOR}+)"; fails=$((fails+1))
  fi

  if [ ! -f .env ]; then
    say "  ${C_DIM}(the notes below only matter if you're setting up a project in this folder; ignore them if you're just working on Laradock itself)${C_RESET}"
  fi

  if [ -f .env ]; then ok ".env exists"; else note ".env missing → run ./laradock setup (or cp .env.example .env)"; warns=$((warns+1)); fi

  local name; name=$(env_get COMPOSE_PROJECT_NAME)
  if [ -n "$name" ]; then
    if docker compose ls --format '{{.Name}}' 2>/dev/null | grep -vx "$name" | grep -qx "$name"; then :; fi
    ok "project name: $name"
  else
    note "COMPOSE_PROJECT_NAME not set → containers named after this folder; collides if you run several Laradocks"; warns=$((warns+1))
  fi

  local data; data=$(env_get DATA_PATH_HOST)
  # shellcheck disable=SC2088  # literal ~ intended: compose expands it
  [ -n "$data" ] || data="~/.laradock/data"
  case "$data" in
    *"data-"*) ok "data path: $data (project-specific)";;
    *) note "data path: $data is SHARED — two projects would mix database files. Set DATA_PATH_HOST=~/.laradock/data-<name>"; warns=$((warns+1));;
  esac

  # port availability for the chosen services
  local svcs; svcs=$(env_get LARADOCK_SERVICES | tr -d '"')
  if [ -n "$svcs" ]; then
    local pairs="" s
    for s in $svcs; do
      case "$s" in
        nginx|apache2|caddy) pairs="$pairs $(default_of NGINX_HOST_HTTP_PORT 80):$s" ;;
        mysql|mariadb)       pairs="$pairs $(default_of MYSQL_PORT 3306):$s" ;;
        postgres)            pairs="$pairs $(default_of POSTGRES_PORT 5432):$s" ;;
        redis|valkey)        pairs="$pairs $(default_of REDIS_PORT 6379):$s" ;;
        phpmyadmin)          pairs="$pairs $(default_of PMA_PORT 8081):$s" ;;
        workspace)           pairs="$pairs $(default_of WORKSPACE_SSH_PORT 2222):$s $(default_of WORKSPACE_BROWSERSYNC_HOST_PORT 3000):$s $(default_of WORKSPACE_BROWSERSYNC_UI_HOST_PORT 3001):$s $(default_of WORKSPACE_VUE_CLI_SERVE_HOST_PORT 8080):$s $(default_of WORKSPACE_VITE_PORT 5173):$s" ;;
      esac
    done
    local p port svc
    for p in $pairs; do
      port=${p%%:*}; svc=${p#*:}
      if docker compose ps --services 2>/dev/null | grep -qx "$svc"; then
        ok "port $port ($svc) — used by this project (fine)"
      elif command -v nc >/dev/null 2>&1 && nc -z localhost "$port" 2>/dev/null; then
        bad "port $port ($svc) is taken by something else → override its *_PORT in .env"; fails=$((fails+1))
      else
        ok "port $port ($svc) free"
      fi
    done
  fi
  say ""
  if [ "$fails" -gt 0 ]; then
    bold "  ${fails} problem(s) — fix the ${BAD} lines above."
  elif [ "$warns" -gt 0 ]; then
    bold "  No blockers, ${warns} note(s) above (expected before you run ./laradock setup)."
  else
    bold "  All good. ${OK}"
  fi
  say ""
  return "$fails"
}

# --------------------------------------------------------------------- main

ASSUME_YES=0
setup_color

args=()
for a in "$@"; do
  case "$a" in
    --yes|-y) ASSUME_YES=1 ;;
    *) args+=("$a") ;;
  esac
done
set -- ${args[@]+"${args[@]}"}

cmd=${1:-help}
[ $# -gt 0 ] && shift

case "$cmd" in
  setup)   cmd_setup "$@" ;;
  up|start) cmd_up "$@" ;;
  # plain-English verbs so non-technical users never meet a docker flag
  # (stop/restart aren't here: they're already the docker verb, so the pass-through
  #  at the bottom handles them identically. They stay listed in `help` regardless.)
  remove|delete) require_laradock_dir; run rm -sf "$@" ;;   # stop + remove; no scary -f to type
  logs)    require_laradock_dir; run logs "${@:---tail=100}" ;;
  rebuild) require_laradock_dir; run build "$@" ;;
  enter)   cmd_enter "$@" ;;
  workspace|ws|shell) cmd_workspace "$@" ;;
  test)    cmd_test "$@" ;;
  open)    cmd_open "$@" ;;
  db)      cmd_db "$@" ;;
  share)   cmd_share "$@" ;;
  set)     cmd_set "$@" ;;
  settings) cmd_settings "$@" ;;
  unset)   cmd_unset "$@" ;;
  edit)    cmd_edit "$@" ;;
  info|status) cmd_info "$@" ;;
  doctor)  cmd_doctor "$@" ;;
  ship)    cmd_ship "$@" ;;
  version|--version|-v) say "laradock cli $VERSION" ;;
  help|--help|-h)
    # hrow "verb + args" "description" — pads the plain command text (color codes
    # would break %-Ns width), then colors it so every description column lines up.
    hrow() { printf '    %s%-22s%s%s\n' "$C_CYAN" "$1" "$C_RESET" "$2"; }
    hsec() { printf '\n  %s%s%s\n' "$C_BOLD$C_YELLOW" "$1" "$C_RESET"; }
    printf '\n  %sLaradock CLI%s %s· plain-English commands for your Docker stack%s\n' \
      "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET"

    hsec "Everyday"
    hrow "setup"              "set up your project, or change it later (add/drop services and tools, switch database or PHP version)"
    hrow "start [services]"   "start your stack (or just the services you name)"
    hrow "stop [services]"    "stop them (your data is kept)"
    hrow "restart [services]" "restart them"
    hrow "logs [services]"    "show recent logs"
    hrow "info"               "what's running: URLs, ports, passwords"
    hrow "open [ui]"          "open the app in your browser (or mailpit, phpmyadmin)"
    hrow "doctor"             "check for common problems"

    hsec "Containers"
    hrow "remove [services]"  "delete the containers (data on disk is kept)"
    hrow "rebuild [services]" "apply a version/config change"

    hsec "Settings"
    hrow "set KEY=VALUE"      "change a setting (writes it to your .env)"
    hrow "unset KEY"          "undo a change (back to the default)"
    hrow "settings [service]" "see all settings, and what you changed"
    hrow "edit [service]"     "open your .env, or a service's Dockerfile"

    hsec "Shell"
    hrow "enter <service>"    "open a terminal inside a container (e.g. mysql)"
    hrow "workspace [--root]" "the dev shell (php, composer, node, git)"
    hrow "db"                 "open a SQL shell in your database"

    hsec "Develop"
    hrow "test [args]"        "run your test suite (artisan / pest / phpunit)"
    hrow "share"              "get a public URL to your local site (cloudflared / ngrok)"

    hsec "Deploy"
    hrow "ship [--push]"      "build a deployable production image (amd64-safe on Apple Silicon)"

    printf '\n  %sAdvanced: anything else is passed straight to docker compose\n' "$C_DIM"
    printf '  (./laradock ps, ./laradock config ...). Plain docker compose works too.%s\n' "$C_RESET"
    printf '  %sFlags:%s --yes (-y) accept all defaults (CI-friendly). NO_COLOR honored.\n\n' \
      "$C_BOLD" "$C_RESET"
    ;;
  *)
    # transparent pass-through to docker compose
    require_laradock_dir
    printf '  %s%s docker compose %s %s%s\n' "$C_DIM" "$ARROW" "$cmd" "$*" "$C_RESET" >&2
    exec docker compose "$cmd" "$@"
    ;;
esac
