# Laradock production config — copy to `production/.env`, fill real values.
# NEVER commit this filled in, NEVER bake it into the image (see dockerignore.sample).

APP_NAME=laradock-app
APP_IMAGE=laradock-app:latest
PHP_VERSION=8.3
HTTP_PORT=80

# --- App (these are Laravel's names; rename for Symfony/WordPress/etc) ---
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://example.com

# --- Database: point at a MANAGED db, not a container ---
DB_CONNECTION=mysql
DB_HOST=your-managed-db-host
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=

# --- Cache / queue: managed redis ---
REDIS_HOST=your-managed-redis-host
REDIS_PORT=6379

# --- Optional processes (enable with compose --profile worker / --profile scheduler) ---
WORKER_COMMAND=php artisan queue:work --tries=3 --timeout=90
SCHEDULER_COMMAND=php artisan schedule:run
