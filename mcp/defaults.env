# Database MCP server: lets AI coding agents (Claude, Cursor, Codex) inspect your
# schema and run read-only queries against laradock's database.
# Edit mcp/dbhub.toml to change which tools agents get.
MCP_VERSION=latest

MCP_HOST_PORT=8321

# Which database to expose. The host is the laradock service name, so start that
# service too (e.g. `./laradock start mcp mysql`).
# mysql://    mariadb://    postgres://    sqlserver://
MCP_DSN=mysql://default:secret@mysql:3306/default
